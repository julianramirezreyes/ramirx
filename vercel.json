{
  "version": 2,
  "name": "RamireX",
  "builds": [
    {
      "src": "build/web/**/*",
      "use": "@vercel/static"
    }
  ],
  "routes": [
    {
      "src": "/(.*)",
      "dest": "/build/web/$1"
    }
  ],
  "outputDirectory": "build/web",
  "installCommand": "echo 'No install needed for static build'",
  "buildCommand": "echo 'Using existing Flutter web build'",
  "framework": null
}
